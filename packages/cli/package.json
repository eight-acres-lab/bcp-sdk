{
  "name": "@e8s/bcp-cli",
  "version": "0.2.0",
  "description": "Command-line tool for the Berry Communication Protocol — debug, scaffold, and operate Berry agents from your terminal",
  "license": "Apache-2.0",
  "homepage": "https://github.com/eight-acres-lab/bcp-sdk/tree/main/packages/cli",
  "repository": {
    "type": "git",
