{
  "name": "@vbox/bcp-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Vbox Berry Communication Protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
